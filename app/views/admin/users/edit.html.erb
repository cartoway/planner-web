<% javascript 'user' %>

<% content_for :title, t('.title') %>

<h1><%= t '.title' %></h1>

<%= bootstrap_form_for [:admin, @user], layout: :horizontal do |f| %>
  <%= render 'shared/error_messages', model: @user %>
  <%= hidden_field_tag :url, params[:url] %>
  <%= f.email_field :email, required: true, autocomplete: "off" %>
  <%= f.password_field :password, required: false, help: t('admin.users.edit.password_optional_note') %>
  <%= f.password_field :password_confirmation, required: false %>
  <%= render partial: 'users/time_zone' %>
  <%= f.collection_select :customer_id, @customers, :id, :name, {}, {class: 'form-control'} %>
  <%= render partial: 'role_field', locals: { f: f } %>
  <div class='row'>
    <div class='col-md-offset-2 col-md-7'>
      <a href="/?api_key=<%= @user.api_key %>"><%= t '.connect_as' %></a>
    </div>
  </div>
  <%= f.submit %>
<% end %>
