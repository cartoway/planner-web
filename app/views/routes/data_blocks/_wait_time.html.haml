- ui_order = local_assigns.fetch(:ui_order, 0)
- if route[:vehicle_id]
  - w = route[:wait_time] || route['wait_time']
  .col-xs-4{style: "order: #{ui_order}"}
    .primary.route-info{title: t('plannings.edit.route_wait_time_help')}
      %i.fa.fa-hourglass-half.fa-fw{"aria-hidden" => "true"}>
      = w.present? ? w : time_over_day(0)
