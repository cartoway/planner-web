%table{ id: "accordion-#{vehicle_usage_set.id}", class: 'table table-striped table-hover' }
  %caption
    %label
      %input.select-unselect-all{ type: 'checkbox', data: { id: vehicle_usage_set.id }, disabled: !can_update_vehicle_usage }
      = t('vehicle_usages.index.select_unselect_all')
  %thead
    %th= t('activerecord.attributes.vehicle.name')
    %th= t('activerecord.attributes.vehicle.router_id')
    %th
      = t('activerecord.attributes.vehicle.emission')
      = ' - '
      = t('activerecord.attributes.vehicle.consumption')
    %th= t('vehicle_usages.index.capacities')
    %th= t('vehicle_usages.index.stores')
    %th= t('vehicle_usage_sets.index.time')
    %th= t('vehicle_usages.index.devices')
    %th
  %tbody
    - vehicle_usage_set.vehicle_usages.each do |vehicle_usage|
      %tr{ class: ('disabled' unless vehicle_usage.active) }
        %td
          %label{ for: "vehicle_usage_vehicle_#{vehicle_usage.id}" }
            %input.vehicle-select{ type: 'checkbox', id: "vehicle_usage_vehicle_#{vehicle_usage.id}", name: "vehicle_usages[#{vehicle_usage_set.id}][#{vehicle_usage.id}]", disabled: !can_update_vehicle_usage }
            .vehicle_color{ style: "background:#{vehicle_usage.vehicle.color}" }
            = vehicle_usage.vehicle.name
        %td= vehicle_usage_router(vehicle_usage)
        %td= vehicle_usage_emission_consumption(vehicle_usage, current_user.prefered_unit)
        %td= vehicle_capacities(vehicle_usage.vehicle)
        %td= vehicle_usage_store_name(vehicle_usage)
        %td= vehicle_usage_store_hours(vehicle_usage)
        %td= vehicle_devices(vehicle_usage.vehicle)
        %td.text-right
          - toggle_icon = vehicle_usage.active ? 'fa-power-off' : 'fa-circle-notch'
          - toggle_label = vehicle_usage.active ? t('.disable') : t('.enable')
          - toggle_data = vehicle_usage.active ? { confirm: t('.disable_confirm') } : {}
          - if vehicle_usage.active
            - unless can_view_vehicle_usage
              %button.btn.btn-primary.btn-sm{ type: 'button', disabled: true }
                %i.fa.fa-edit.fa-fw
                = t('all.verb.edit')
            - else
              = link_to edit_vehicle_usage_path(vehicle_usage, back: true), class: 'btn btn-primary btn-sm' do
                %i.fa.fa-edit.fa-fw
                = t('all.verb.edit')
          - if can_update_vehicle_usage
            = link_to [:toggle, vehicle_usage], method: :patch, class: 'btn btn-default btn-sm', data: toggle_data do
              %i.fa.fa-fw{ class: toggle_icon }
              = toggle_label
          - else
            %button.btn.btn-default.btn-sm{ type: 'button', disabled: true }
              %i.fa.fa-fw{ class: toggle_icon }
              = toggle_label

.row{ id: "multiple-actions-#{vehicle_usage_set.id}" }
  .col-md-12
    = button_tag type: :submit,
                 class: 'btn btn-default btn-sm btn-disable',
                 name: 'disable_multiple',
                 value: vehicle_usage_set.id.to_s,
                 disabled: vehicle_usage_set.vehicle_usages.count == 1 || !can_update_vehicle_usage,
                 data: { confirm: t('vehicle_usages.index.multiple_disable_confirm'), id: vehicle_usage_set.id } do
      %i.fa.fa-power-off.fa-fw
      = t('vehicle_usages.index.multiple_disable')
    = button_tag type: :submit,
                 class: 'btn btn-default btn-sm btn-enable',
                 name: 'enable_multiple',
                 value: vehicle_usage_set.id.to_s,
                 disabled: vehicle_usage_set.vehicle_usages.count == 1 || !can_update_vehicle_usage,
                 data: { id: vehicle_usage_set.id } do
      %i.fa.fa-truck-field.fa-fw
      = t('vehicle_usages.index.multiple_enable')
