.row.in-route.route-data{"data-route-id": route_data[:route_id]}
  - if route_data[:vehicle_id]
    - if route_data[:route_averages]
      - if route_data[:total_revenue]
        .col-xs-4{title: t('plannings.edit.revenue_help')}
          .primary.route-info
            %i.fa.fa-hand-holding-dollar.fa-fw
            = route_data[:total_revenue]
            = t("all.unit.currency_symbol.#{route_data[:route_averages][:prefered_currency]}")
      - if route_data[:total_cost]
        .col-xs-4{title: t('plannings.edit.cost_help')}
          .primary.route-info
            %i.fa.fa-coins.fa-fw
            = route_data[:total_cost]
            = t("all.unit.currency_symbol.#{route_data[:route_averages][:prefered_currency]}")
      - if route_data[:total_revenue] && route_data[:total_cost]
        .col-xs-4{title: t('plannings.edit.balance_help')}
          .route-info{ class: (route_data[:total_balance] < 0 ? 'danger' : route_data[:total_balance] == 0 ? 'secondary' : 'success')}
            %i.fa.fa-scale-balanced.fa-fw
            = route_data[:total_balance]
            = t("all.unit.currency_symbol.#{route_data[:route_averages][:prefered_currency]}")
    - if route_data[:duration]
      .col-xs-4
        .route-info.primary{class: ('danger' if route_data[:route_out_of_drive_time] || route_data[:route_out_of_work_time]), title: t('plannings.edit.route_duration_help')}
          %i.fa.fa-stopwatch.fa-fw>
          = route_data[:duration]
          - if route_data[:work_or_window_time]
            \/
            = route_data[:work_or_window_time]
    - if route_data[:distance]
      .col-xs-4
        .route-info.primary{class: ('danger' if route_data[:route_out_of_max_distance]), title: t('plannings.edit.route_distance_help')}
          %i.fa.fa-road.fa-fw>
          = route_data[:distance]
    - if route_data[:route_averages]
      .col-xs-4
        .primary.route-info{title: t('plannings.edit.route_speed_average_help')}
          %i.fa.fa-tachometer.fa-fw{"aria-hidden" => "true"}>
          = route_data[:route_averages][:speed]
          = route_data[:route_averages][:prefered_unit]
          \/h
      .col-xs-4{title: t('plannings.edit.emission_help')}
        .primary.route-info
          %i.fa.fa-flask.fa-fw
          = route_data[:emission]
          = t('all.unit.kgco2e_html')
  - route_data[:quantities]&.each do |unit|
    - [:pickup, :delivery].each do |sym|
      - if unit.fetch("has_#{sym}".to_sym)
        .col-xs-4.route-data-advanced
          .route-info{class: "#{route_data[:vehicle_id] ? 'primary' : 'inactive'} #{unit[:out_of_capacity] && 'danger'}", title: [unit[:label], sym == :pickup ? t('plannings.edit.route_data_pickup_help') : t('plannings.edit.route_data_delivery_help')].compact.join(' - ')}
            %i.fa.fa-fw{class: unit[:unit_icon]}
            - if sym == :pickup
              %i.fa.fa-fw.fa-up-long{title: t("plannings.edit.route_data_pickup_help")}
              = unit[:pickup]
            - if sym == :delivery
              %i.fa.fa-fw.fa-down-long{title: t("plannings.edit.route_data_delivery_help")}
              = unit[:delivery]
            - if unit[:capacity]
              = "/ #{unit[:capacity]}"
            /
            - if unit[:label]
              = "#{unit[:label]}"
