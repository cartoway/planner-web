.form-group
  .row
    %label{ class: label_col_classes }
      = t('admin.roles.form.forms_title')
    %div{ class: field_col_classes }
      = hidden_field_tag "#{param_prefix}[forms_ui]", '1'
      - active_forms, disabled_forms, hidden_forms = record.forms_resources_three_way_split
      .active-inactive-zones.role-forms-dnd.role-forms-three-zones{ id: cid_forms, "data-drag-drop" => "generic", "data-drag-drop-options" => forms_opts.to_json }
        .forms-three-columns
          .forms-tier-active.priority-active.active-zone
            .zone-title= t('users.form.display_ui.operations_active')
            .item-list
              - active_forms.each_with_index do |fid, index|
                .draggable-item{ data: { value: fid, index: index } }
                  %span.item-order
                  %span.item-text= t("activerecord.models.#{fid}.other", default: fid.to_s.humanize)
                  %input{ type: 'hidden', name: "#{param_prefix}[forms_active][]", value: fid }
          .forms-tier-disabled.priority-disabled.disabled-zone
            .zone-title= t('users.form.display_ui.operations_disabled')
            .item-list
              - disabled_forms.each_with_index do |fid, index|
                .draggable-item{ data: { value: fid, index: index } }
                  %span.item-order
                  %span.item-text= t("activerecord.models.#{fid}.other", default: fid.to_s.humanize)
                  %input{ type: 'hidden', name: "#{param_prefix}[forms_disabled][]", value: fid }
          .forms-tier-hidden.priority-inactive.inactive-zone
            .zone-title= t('users.form.display_ui.operations_hidden')
            .item-list
              - hidden_forms.each_with_index do |fid, index|
                .draggable-item.inactive{ data: { value: fid, index: index } }
                  %span.item-order
                  %span.item-text= t("activerecord.models.#{fid}.other", default: fid.to_s.humanize)
      %p.help-block= t('admin.roles.form.forms_help')
