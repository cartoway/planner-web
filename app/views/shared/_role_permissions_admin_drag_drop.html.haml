      .priority-zones.active-inactive-zones.operations-toolbar-dnd.operations-three-zones{ id: cid_or, "data-drag-drop" => "generic", "data-drag-drop-options" => Preferences::DragDropOptions.operations_three_zone_options(param_prefix, 'route').to_json }
        .operations-three-columns
